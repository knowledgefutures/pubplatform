{
	"name": "site-builder-2",
	"type": "module",
	"private": true,
	"version": "0.0.1",
	"scripts": {
		"type-check": "tsc --noEmit",
		"dev": "pnpm server:dev",
		"start": "tsx server/server.ts",
		"server:start": "tsx server/server.ts",
		"server:dev": "tsx --env-file=.env.server.development --env-file=.env.server.development.local --watch server/server.ts",
		"docker:build": "docker build -f ../Dockerfile .. -t site-builder:latest --progress=plain --build-arg PACKAGE=site-builder --target jobs"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.525.0",
		"@aws-sdk/lib-storage": "^3.787.0",
		"@hono/node-server": "^1.14.1",
		"@hono/zod-validator": "^0.4.3",
		"@t3-oss/env-core": "^0.12.0",
		"@ts-rest/core": "catalog:",
		"@ts-rest/serverless": "^3.52.1",
		"archiver": "^6.0.2",
		"contracts": "workspace:",
		"dotenv": "^16.4.5",
		"hono": "^4.9.7",
		"logger": "workspace:*",
		"mime-types": "^2.1.35",
		"tsconfig": "workspace:*",
		"tsx": "^4.19.3",
		"utils": "workspace:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@types/archiver": "^6.0.2",
		"@types/mime-types": "^2.1.4",
		"@types/node": "22",
		"dotenv-cli": "^5.0.1"
	}
}